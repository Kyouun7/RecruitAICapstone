# Required GitLab CI/CD variables for deploy_production.
# Store real values in GitLab Settings > CI/CD > Variables, not in the repo.

DEPLOY_BRANCH=main

DB_NAME=recruitmen_db
DB_USER=recruitai
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

JWT_SECRET=change-me-long-random-secret

FRONTEND_URL=https://frontend.example.com
NEXT_PUBLIC_APP_URL=https://frontend.example.com
# Leave empty/delete this for Cloudflare tunnel mode so the frontend uses same-origin /api.
NEXT_PUBLIC_API_URL=
CORS_ORIGINS=https://frontend.example.com

N8N_WEBHOOK_URL=https://workflow.jagr.id/webhook/candidate
N8N_SECRET=

BACKEND_PORT=3000
FRONTEND_PORT=3001
PUBLIC_PORT=8080

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
