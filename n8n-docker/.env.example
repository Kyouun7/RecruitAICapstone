# Local n8n defaults
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_BASE_URL=http://localhost:5678/

# Backend URL that n8n can call back after scoring.
# Local Docker Desktop: http://host.docker.internal:3000
# Production example: https://api.example.com
BACKEND_API_URL=http://host.docker.internal:3000

GROQ_API_KEY=
