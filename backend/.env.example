# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=recruitmen_db

# Auth
JWT_SECRET=your-strong-secret-key-here

# Server
PORT=3000

# ─── Google Drive ──────────────────────────────────────────────────────────────
# Option A: place client_secret.json + token.json in the backend/ folder
#           then run: node auth.js
#
# Option B: fill these env vars (get values from Google Cloud Console + token.json)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=your-refresh-token-from-token-json
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
# ───────────────────────────────────────────────────────────────────────────────

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
FRONTEND_URL=http://localhost:3001

# n8n Integration
N8N_WEBHOOK_URL=http://localhost:5678/webhook/candidate
N8N_SECRET=your-strong-n8n-secret-here
